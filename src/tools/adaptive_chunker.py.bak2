- 李四：编写测试用例
- 王五：部署测试环境
"""
        }
    ]
    
    print("="*70)
    print("🧪 AdaptiveChunker 测试报告")
    print("="*70)
    
    for case in test_cases:
        print(f"\n{'='*70}")
        print(f"📄 文件：{case['file']}")
        print(f"{'='*70}")
        
        # 分析文档类型
        info = chunker.get_doc_type_info(case['file'], case['content'])
        print(f"🔍 检测类型：{info['detected_type']} ({info['type_name']})")
        print(f"📝 描述：{info['description']}")
        print(f"🔧 检测理由：{info['reasoning']}")
        
        print(f"\n📊 标题结构:")
        print(f"   最大层级：H{info['heading_structure']['max_level']}")
        print(f"   章节数量：{info['heading_structure']['section_count']}")
        
        print(f"\n⚙️ 参数配置:")
        print(f"   基准：chunk_size={info['config']['base_chunk_size']}, overlap={info['config']['base_overlap']}")
        print(f"   调整系数：{info['config']['heading_adjustments']}")
        
        print(f"\n📏 各层级实际参数:")
        for level, cfg in info['adjusted_configs'].items():
            print(f"   {level}: chunk_size={cfg['chunk_size']}, overlap={cfg['overlap']}")
        
        # 执行分块
        chunks = chunker.chunk_file(case['file'], case['content'])
        print(f"\n📦 分块结果：{len(chunks)} 个块")
        
        if chunks:
            for i, chunk in enumerate(chunks[:5], 1):
                print(f"   块{i}: {len(chunk.content)}字符, H{chunk.metadata.get('heading_level')}, "
                      f"size={chunk.metadata.get('chunk_size_used')}")
                print(f"        标题：{chunk.metadata.get('title', '无')[:30]}...")
                print(f"        内容：{chunk.content[:80]}...")
        else:
            print("   未生成分块（内容可能过短）")
    
    print(f"\n{'='*70}")
    print("✅ 测试完成")
    print(f"{'='*70}")
